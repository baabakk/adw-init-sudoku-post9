{
  "compilerOptions": {
    "composite": true,
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"]
  },
  "references": [
    {
      "path": "../contracts"
    }
  ],
  "include": ["src/**/*.tsx", "src/**/*.ts"],
  "exclude": ["src/index.ts"]
}