{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": true,
    "composite": true,
    "lib": ["ES2022", "DOM"],
    "resolveJsonModule": true
  },
  "include": ["src"],
  "references": [{"path": "../contracts"}]
}
