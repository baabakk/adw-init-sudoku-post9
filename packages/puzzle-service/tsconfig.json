{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "composite": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["DOM", "DOM.Iterable", "ES2022"]
  },
  "include": ["src"],
  "references": [{"path": "../contracts"}]
}
